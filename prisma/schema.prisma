datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum Role {
  ADMIN
  STAFF
  GUEST
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String
  phone     String?
  role      Role     @default(GUEST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateLimit {
  key       String   @id
  attempts  Int
  expiresAt DateTime
}
