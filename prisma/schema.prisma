datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum Role {
  ADMIN
  STAFF
  GUEST
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String
  phone     String?
  role      Role     @default(GUEST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateLimit {
  key       String   @id
  attempts  Int
  expiresAt DateTime
}

model SystemSettings {
  key   String @id
  value String
}

model Room {
  id            String   @id @default(uuid())
  name          String
  description   String
  pricePerNight Float
  capacity      Int
  imageUrl      String
  size          String
  amenities     String[]
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Booking {
  id            String   @id @default(uuid())
  reference     String   @unique
  guestName     String
  guestEmail    String?
  guestPhone    String?
  roomId        String
  roomName      String
  pricePerNight Float
  checkIn       DateTime
  checkOut      DateTime
  nights        Int
  totalPrice    Float
  status        String   @default("CONFIRMED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
